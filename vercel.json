{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/events/:eventId/supply-list",
      "destination": "/api/supply-list-viewer?eventId=:eventId"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
