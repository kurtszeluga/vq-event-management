rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validStatus(value, statuses) {
      return value is string && value in statuses;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActiveProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserData().status == 'Active';
    }

    function isSuperUser() {
      return isActiveProfile() && currentUserData().role == 'Super User';
    }

    function isAdmin() {
      return isActiveProfile()
        && currentUserData().role in ['Super User', 'Admin'];
    }

    function hasPermission(permissionKey) {
      return isSuperUser()
        || isActiveProfile()
          && currentUserData().role == 'Admin'
          && currentUserData().permissions[permissionKey] == true;
    }

    function isOwner(userId) {
      return signedIn() && userId == request.auth.uid;
    }

    function validEvent() {
      return request.resource.data.keys().hasOnly([
          'eventId',
          'allowCashCheckPayment',
          'allowNonMemberRegistration',
          'type',
          'address',
          'askingPrice',
          'businessName',
          'contactEmail',
          'contactName',
          'contactPhone',
          'eventType',
          'title',
          'description',
          'documentFileName',
          'documentTitle',
          'documentUrl',
          'presenter',
          'date',
          'timePreset',
          'startTime',
          'endTime',
          'locationPreset',
          'location',
          'capacity',
          'capacityUnlimited',
          'isPaid',
          'cost',
          'serviceFee',
          'status',
          'registrationOpen',
          'registrationMode',
          'registrationOpenAt',
          'registrationCloseAt',
          'listingMode',
          'visibleFrom',
          'visibleUntil',
          'imageUrls',
          'ownerName',
          'specialty',
          'supplyListFileName',
          'supplyListTitle',
          'supplyListUrl',
          'additionalNotes',
          'createdBy',
          'createdDate',
          'updatedDate'
        ])
        && request.resource.data.title is string
        && (!('allowCashCheckPayment' in request.resource.data)
          || request.resource.data.allowCashCheckPayment is bool)
        && (!('allowNonMemberRegistration' in request.resource.data)
          || request.resource.data.allowNonMemberRegistration is bool)
        && (!('address' in request.resource.data) || request.resource.data.address is string)
        && (!('askingPrice' in request.resource.data) || request.resource.data.askingPrice is number)
        && (!('businessName' in request.resource.data) || request.resource.data.businessName is string)
        && (!('contactEmail' in request.resource.data) || request.resource.data.contactEmail is string)
        && (!('contactName' in request.resource.data) || request.resource.data.contactName is string)
        && (!('contactPhone' in request.resource.data) || request.resource.data.contactPhone is string)
        && request.resource.data.eventType is string
        && request.resource.data.description is string
        && (!('documentFileName' in request.resource.data) || request.resource.data.documentFileName is string)
        && (!('documentTitle' in request.resource.data) || request.resource.data.documentTitle is string)
        && (!('documentUrl' in request.resource.data) || request.resource.data.documentUrl is string)
        && request.resource.data.date is string
        && request.resource.data.timePreset is string
        && request.resource.data.startTime is string
        && request.resource.data.endTime is string
        && request.resource.data.locationPreset is string
        && request.resource.data.location is string
        && request.resource.data.capacity is number
        && request.resource.data.capacityUnlimited is bool
        && request.resource.data.isPaid is bool
        && request.resource.data.cost is number
        && request.resource.data.serviceFee is number
        && validStatus(request.resource.data.status, ['Draft', 'Published', 'Closed', 'Cancelled', 'Archived'])
        && request.resource.data.registrationOpen is bool
        && request.resource.data.registrationMode is string
        && request.resource.data.listingMode is string
        && request.resource.data.imageUrls is list
        && (!('ownerName' in request.resource.data) || request.resource.data.ownerName is string)
        && (!('specialty' in request.resource.data) || request.resource.data.specialty is string)
        && request.resource.data.supplyListFileName is string
        && request.resource.data.supplyListTitle is string
        && request.resource.data.supplyListUrl is string
        && request.resource.data.createdBy is string
        && request.resource.data.createdDate is timestamp;
    }

    function validRegistration() {
      return request.resource.data.keys().hasOnly([
          'registrationId',
          'eventId',
          'amountDue',
          'amountPaid',
          'eventCost',
          'eventDate',
          'eventPaymentRequired',
          'eventServiceFee',
          'eventTitle',
          'eventType',
          'userId',
          'name',
          'email',
          'membershipStatusAtRegistration',
          'phone',
          'profileMatchedAtRegistration',
          'profileStatusAtRegistration',
          'registrationDate',
          'registrantFirstName',
          'registrantLastName',
          'paymentMethod',
          'paymentNote',
          'paymentStatus',
          'paymentUpdatedDate',
          'status'
        ])
        && request.resource.data.eventId is string
        && (!('amountDue' in request.resource.data) || request.resource.data.amountDue is number)
        && (!('amountPaid' in request.resource.data) || request.resource.data.amountPaid is number)
        && (!('eventCost' in request.resource.data) || request.resource.data.eventCost is number)
        && (!('eventDate' in request.resource.data) || request.resource.data.eventDate is string)
        && (!('eventPaymentRequired' in request.resource.data) || request.resource.data.eventPaymentRequired is bool)
        && (!('eventServiceFee' in request.resource.data) || request.resource.data.eventServiceFee is number)
        && (!('eventTitle' in request.resource.data) || request.resource.data.eventTitle is string)
        && (!('eventType' in request.resource.data) || request.resource.data.eventType is string)
        && request.resource.data.name is string
        && request.resource.data.email is string
        && (!('membershipStatusAtRegistration' in request.resource.data)
          || validStatus(request.resource.data.membershipStatusAtRegistration, ['Pending', 'Active', 'Inactive', 'Archived', 'Unknown']))
        && request.resource.data.phone is string
        && (!('profileMatchedAtRegistration' in request.resource.data)
          || request.resource.data.profileMatchedAtRegistration is bool)
        && (!('profileStatusAtRegistration' in request.resource.data)
          || validStatus(request.resource.data.profileStatusAtRegistration, ['Active', 'Inactive', 'Archived', 'Unknown', '']))
        && request.resource.data.registrationDate is timestamp
        && (!('registrantFirstName' in request.resource.data) || request.resource.data.registrantFirstName is string)
        && (!('registrantLastName' in request.resource.data) || request.resource.data.registrantLastName is string)
        && (!('paymentMethod' in request.resource.data)
          || validStatus(request.resource.data.paymentMethod, ['', 'None', 'Online', 'Cash', 'Check', 'Comped']))
        && (!('paymentNote' in request.resource.data) || request.resource.data.paymentNote is string)
        && validStatus(request.resource.data.paymentStatus, ['Pending', 'Paid', 'Refunded', 'Failed', 'Waived', 'No Charge'])
        && (!('paymentUpdatedDate' in request.resource.data)
          || request.resource.data.paymentUpdatedDate is timestamp)
        && validStatus(request.resource.data.status, ['Pending Payment', 'Registered', 'Cancelled', 'Waitlisted'])
        && (!('userId' in request.resource.data) || request.resource.data.userId is string)
        && (hasPermission('viewRegistrations')
          || !signedIn()
          || !('userId' in request.resource.data)
          || request.resource.data.userId == request.auth.uid);
    }

    function validUser() {
        return request.resource.data.keys().hasOnly([
          'userId',
          'billingAddress',
          'archivedBy',
          'archivedDate',
          'firstName',
          'lastName',
          'name',
          'email',
          'membershipMatchedBy',
          'membershipMemberId',
          'membershipPaymentAmount',
          'membershipPaymentMethod',
          'membershipPaymentNote',
          'membershipPaymentStatus',
          'membershipPaymentUpdatedDate',
          'membershipReviewNote',
          'membershipReviewedBy',
          'membershipReviewedDate',
          'membershipStatus',
          'membershipUpdatedDate',
          'phone',
          'permissions',
          'profileTags',
          'role',
          'status',
          'termsAccepted',
          'termsAcceptedDate',
          'termsVersion',
          'createdDate',
          'updatedDate'
        ])
        && request.resource.data.userId is string
        && (!('billingAddress' in request.resource.data)
          || request.resource.data.billingAddress is map
            && request.resource.data.billingAddress.keys().hasOnly([
              'street',
              'city',
              'state',
              'postalCode',
              'country'
            ])
            && request.resource.data.billingAddress.street is string
            && request.resource.data.billingAddress.city is string
            && request.resource.data.billingAddress.state is string
            && request.resource.data.billingAddress.postalCode is string
            && request.resource.data.billingAddress.country is string)
        && request.resource.data.name is string
        && (!('firstName' in request.resource.data)
          || request.resource.data.firstName is string)
        && (!('lastName' in request.resource.data)
          || request.resource.data.lastName is string)
        && request.resource.data.email is string
        && (!('archivedBy' in request.resource.data)
          || request.resource.data.archivedBy is string)
        && (!('archivedDate' in request.resource.data)
          || request.resource.data.archivedDate is timestamp)
        && (!('membershipMatchedBy' in request.resource.data)
          || validStatus(request.resource.data.membershipMatchedBy, ['email', 'phone', 'csv', 'manual', 'account', '']))
        && (!('membershipMemberId' in request.resource.data)
          || request.resource.data.membershipMemberId is string)
        && (!('membershipPaymentAmount' in request.resource.data)
          || request.resource.data.membershipPaymentAmount is number)
        && (!('membershipPaymentMethod' in request.resource.data)
          || validStatus(request.resource.data.membershipPaymentMethod, ['', 'Cash', 'Check', 'Comped']))
        && (!('membershipPaymentNote' in request.resource.data)
          || request.resource.data.membershipPaymentNote is string)
        && (!('membershipPaymentStatus' in request.resource.data)
          || validStatus(request.resource.data.membershipPaymentStatus, ['Pending', 'Paid', 'Refunded', 'Waived']))
        && (!('membershipPaymentUpdatedDate' in request.resource.data)
          || request.resource.data.membershipPaymentUpdatedDate is timestamp)
        && (!('membershipReviewNote' in request.resource.data)
          || request.resource.data.membershipReviewNote is string)
        && (!('membershipReviewedBy' in request.resource.data)
          || request.resource.data.membershipReviewedBy is string)
        && (!('membershipReviewedDate' in request.resource.data)
          || request.resource.data.membershipReviewedDate is timestamp)
        && (!('membershipStatus' in request.resource.data)
          || validStatus(request.resource.data.membershipStatus, ['Pending', 'Active', 'Inactive', 'Archived', 'Unknown']))
        && (!('membershipUpdatedDate' in request.resource.data)
          || request.resource.data.membershipUpdatedDate is timestamp)
        && request.resource.data.phone is string
        && request.resource.data.permissions is map
        && (!('profileTags' in request.resource.data)
          || request.resource.data.profileTags is list
            && request.resource.data.profileTags.size() <= 20
            && request.resource.data.profileTags.hasOnly([
              'vqBooking',
              'vqHosting',
              'teacher',
              'volunteer'
            ]))
        && request.resource.data.permissions.keys().hasOnly([
          'manageEvents',
          'viewRegistrations',
          'managePayments',
          'addUsers',
          'manageMembershipStatus'
        ])
        && request.resource.data.permissions.manageEvents is bool
        && request.resource.data.permissions.viewRegistrations is bool
        && request.resource.data.permissions.managePayments is bool
        && (!('addUsers' in request.resource.data.permissions)
          || request.resource.data.permissions.addUsers is bool)
        && request.resource.data.permissions.manageMembershipStatus is bool
        && validStatus(request.resource.data.role, ['Super User', 'Admin', 'General User'])
        && validStatus(request.resource.data.status, ['Active', 'Inactive', 'Archived'])
        && (!('termsAccepted' in request.resource.data)
          || request.resource.data.termsAccepted is bool)
        && (!('termsAcceptedDate' in request.resource.data)
          || request.resource.data.termsAcceptedDate is timestamp)
        && (!('termsVersion' in request.resource.data)
          || request.resource.data.termsVersion is string)
        && (request.resource.data.role == 'Super User'
          || request.resource.data.role == 'Admin'
            && request.resource.data.status == 'Active'
            && request.resource.data.membershipStatus == 'Active'
          || request.resource.data.role == 'General User'
            && hasNoAdminPermissions())
        && request.resource.data.createdDate is timestamp;
    }

    function validSelfUserCreate(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == userId
        && request.resource.data.role == 'General User'
        && request.resource.data.status == 'Active'
        && request.resource.data.termsAccepted == true
        && request.resource.data.termsAcceptedDate is timestamp
        && request.resource.data.termsVersion is string;
    }

    function hasNoAdminPermissions() {
      return request.resource.data.permissions.manageEvents == false
        && request.resource.data.permissions.viewRegistrations == false
        && request.resource.data.permissions.managePayments == false
        && request.resource.data.permissions.manageMembershipStatus == false
        && (!('addUsers' in request.resource.data.permissions)
          || request.resource.data.permissions.addUsers == false);
    }

    function canManageMembershipStatus() {
      return isAdmin()
        && currentUserData().permissions.manageMembershipStatus == true;
    }

    function profileTagsUnchanged() {
      return !('profileTags' in resource.data) && !('profileTags' in request.resource.data)
        || 'profileTags' in resource.data
          && 'profileTags' in request.resource.data
          && request.resource.data.profileTags == resource.data.profileTags;
    }

    function membershipFieldsUnchanged() {
      return (!('membershipMatchedBy' in resource.data) && !('membershipMatchedBy' in request.resource.data)
          || 'membershipMatchedBy' in resource.data
            && 'membershipMatchedBy' in request.resource.data
            && request.resource.data.membershipMatchedBy == resource.data.membershipMatchedBy)
        && (!('membershipMemberId' in resource.data) && !('membershipMemberId' in request.resource.data)
          || 'membershipMemberId' in resource.data
            && 'membershipMemberId' in request.resource.data
            && request.resource.data.membershipMemberId == resource.data.membershipMemberId)
        && (!('membershipPaymentAmount' in resource.data) && !('membershipPaymentAmount' in request.resource.data)
          || 'membershipPaymentAmount' in resource.data
            && 'membershipPaymentAmount' in request.resource.data
            && request.resource.data.membershipPaymentAmount == resource.data.membershipPaymentAmount)
        && (!('membershipPaymentMethod' in resource.data) && !('membershipPaymentMethod' in request.resource.data)
          || 'membershipPaymentMethod' in resource.data
            && 'membershipPaymentMethod' in request.resource.data
            && request.resource.data.membershipPaymentMethod == resource.data.membershipPaymentMethod)
        && (!('membershipPaymentNote' in resource.data) && !('membershipPaymentNote' in request.resource.data)
          || 'membershipPaymentNote' in resource.data
            && 'membershipPaymentNote' in request.resource.data
            && request.resource.data.membershipPaymentNote == resource.data.membershipPaymentNote)
        && (!('membershipPaymentStatus' in resource.data) && !('membershipPaymentStatus' in request.resource.data)
          || 'membershipPaymentStatus' in resource.data
            && 'membershipPaymentStatus' in request.resource.data
            && request.resource.data.membershipPaymentStatus == resource.data.membershipPaymentStatus)
        && (!('membershipPaymentUpdatedDate' in resource.data) && !('membershipPaymentUpdatedDate' in request.resource.data)
          || 'membershipPaymentUpdatedDate' in resource.data
            && 'membershipPaymentUpdatedDate' in request.resource.data
            && request.resource.data.membershipPaymentUpdatedDate == resource.data.membershipPaymentUpdatedDate)
        && (!('membershipReviewNote' in resource.data) && !('membershipReviewNote' in request.resource.data)
          || 'membershipReviewNote' in resource.data
            && 'membershipReviewNote' in request.resource.data
            && request.resource.data.membershipReviewNote == resource.data.membershipReviewNote)
        && (!('membershipReviewedBy' in resource.data) && !('membershipReviewedBy' in request.resource.data)
          || 'membershipReviewedBy' in resource.data
            && 'membershipReviewedBy' in request.resource.data
            && request.resource.data.membershipReviewedBy == resource.data.membershipReviewedBy)
        && (!('membershipReviewedDate' in resource.data) && !('membershipReviewedDate' in request.resource.data)
          || 'membershipReviewedDate' in resource.data
            && 'membershipReviewedDate' in request.resource.data
            && request.resource.data.membershipReviewedDate == resource.data.membershipReviewedDate)
        && (!('membershipStatus' in resource.data) && !('membershipStatus' in request.resource.data)
          || 'membershipStatus' in resource.data
            && 'membershipStatus' in request.resource.data
            && request.resource.data.membershipStatus == resource.data.membershipStatus)
        && (!('membershipUpdatedDate' in resource.data) && !('membershipUpdatedDate' in request.resource.data)
          || 'membershipUpdatedDate' in resource.data
            && 'membershipUpdatedDate' in request.resource.data
            && request.resource.data.membershipUpdatedDate == resource.data.membershipUpdatedDate);
    }

    function membershipStatusEditable() {
      return canManageMembershipStatus()
        && request.resource.data.role == 'General User'
        && (!('membershipMatchedBy' in resource.data) && !('membershipMatchedBy' in request.resource.data)
          || 'membershipMatchedBy' in resource.data
            && 'membershipMatchedBy' in request.resource.data
            && request.resource.data.membershipMatchedBy == resource.data.membershipMatchedBy)
        && (!('membershipMemberId' in resource.data) && !('membershipMemberId' in request.resource.data)
          || 'membershipMemberId' in resource.data
            && 'membershipMemberId' in request.resource.data
            && request.resource.data.membershipMemberId == resource.data.membershipMemberId)
        && (!('membershipReviewNote' in request.resource.data)
          || request.resource.data.membershipReviewNote is string)
        && (!('membershipReviewedBy' in request.resource.data)
          || request.resource.data.membershipReviewedBy is string)
        && (!('membershipReviewedDate' in request.resource.data)
          || request.resource.data.membershipReviewedDate is timestamp)
        && validStatus(request.resource.data.membershipStatus, ['Pending', 'Active', 'Inactive', 'Archived', 'Unknown']);
    }

    function validPayment() {
      return request.resource.data.keys().hasOnly([
          'amount',
          'amountDue',
          'createdBy',
          'createdByEmail',
          'createdByName',
          'createdDate',
          'entityId',
          'entityType',
          'eventId',
          'method',
          'note',
          'paymentId',
          'processor',
          'registrationId',
          'registrationStatus',
          'squareTransactionId',
          'status',
          'updatedMembershipSnapshot',
          'updatedRegistrationSnapshot',
          'userId'
        ])
        && request.resource.data.paymentId is string
        && request.resource.data.amount is number
        && request.resource.data.amountDue is number
        && request.resource.data.createdBy is string
        && request.resource.data.createdByEmail is string
        && request.resource.data.createdByName is string
        && request.resource.data.createdDate is timestamp
        && validStatus(request.resource.data.entityType, ['Registration', 'Membership'])
        && request.resource.data.entityId is string
        && (!('eventId' in request.resource.data) || request.resource.data.eventId is string)
        && validStatus(request.resource.data.method, ['', 'Online', 'Cash', 'Check', 'Comped'])
        && request.resource.data.note is string
        && validStatus(request.resource.data.processor, ['Manual', 'Square'])
        && (!('registrationId' in request.resource.data) || request.resource.data.registrationId is string)
        && (!('registrationStatus' in request.resource.data) || request.resource.data.registrationStatus is string)
        && request.resource.data.squareTransactionId is string
        && validStatus(request.resource.data.status, ['Pending', 'Paid', 'Failed', 'Refunded', 'Waived', 'No Charge'])
        && (!('updatedMembershipSnapshot' in request.resource.data)
          || request.resource.data.updatedMembershipSnapshot is map)
        && request.resource.data.updatedRegistrationSnapshot is map
        && (!('userId' in request.resource.data) || request.resource.data.userId is string);
    }

    function validAuditLog() {
      return request.resource.data.keys().hasOnly([
          'action',
          'actorEmail',
          'actorName',
          'actorRole',
          'actorUserId',
          'after',
          'before',
          'createdDate',
          'entityId',
          'entityType',
          'summary'
        ])
        && validStatus(request.resource.data.action, [
          'Create',
          'Update',
          'Delete',
          'Register',
          'Cancel',
          'Pay',
          'Refund',
          'Archive',
          'Reactivate',
          'Attendance Update'
        ])
        && request.resource.data.actorEmail is string
        && request.resource.data.actorName is string
        && request.resource.data.actorRole is string
        && request.resource.data.actorUserId is string
        && request.resource.data.after is map
        && request.resource.data.before is map
        && request.resource.data.createdDate is timestamp
        && request.resource.data.entityId is string
        && request.resource.data.entityType is string
        && request.resource.data.summary is string;
    }

    function validMembershipSettings() {
      return request.resource.data.keys().hasOnly([
          'allowAdminSkipMembershipCheck',
          'defaultServiceFee',
          'matchByEmail',
          'matchByPhone',
          'requireMembershipCheck',
          'termsText',
          'termsVersion',
          'updatedDate'
        ])
        && request.resource.data.allowAdminSkipMembershipCheck is bool
        && request.resource.data.defaultServiceFee is number
        && request.resource.data.matchByEmail is bool
        && request.resource.data.matchByPhone is bool
        && request.resource.data.requireMembershipCheck is bool
        && (!('termsText' in request.resource.data)
          || request.resource.data.termsText is string)
        && (!('termsVersion' in request.resource.data)
          || request.resource.data.termsVersion is string)
        && request.resource.data.updatedDate is timestamp;
    }

    function validEmailInstructions() {
      return request.resource.data.keys().hasOnly([
          'challenges',
          'membership',
          'programs',
          'sendRegistrationConfirmations',
          'updatedDate',
          'workshops'
        ])
        && request.resource.data.challenges is string
        && request.resource.data.membership is string
        && request.resource.data.programs is string
        && request.resource.data.sendRegistrationConfirmations is bool
        && request.resource.data.workshops is string
        && request.resource.data.updatedDate is timestamp;
    }

    function validPaymentSettings() {
      return request.resource.data.keys().hasOnly([
          'defaultServiceFee',
          'enableApplePay',
          'enableCardPayments',
          'enableGooglePay',
          'updatedDate'
        ])
        && request.resource.data.defaultServiceFee is number
        && request.resource.data.enableApplePay is bool
        && request.resource.data.enableCardPayments is bool
        && request.resource.data.enableGooglePay is bool
        && request.resource.data.updatedDate is timestamp;
    }

    function validMember() {
      return request.resource.data.keys().hasOnly([
          'email',
          'firstName',
          'lastName',
          'memberId',
          'name',
          'normalizedEmail',
          'normalizedPhone',
          'notes',
          'phone',
          'status',
          'archivedBy',
          'archivedDate',
          'updatedDate'
        ])
        && (!('archivedBy' in request.resource.data) || request.resource.data.archivedBy is string)
        && (!('archivedDate' in request.resource.data) || request.resource.data.archivedDate is timestamp)
        && request.resource.data.email is string
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.memberId is string
        && request.resource.data.name is string
        && request.resource.data.normalizedEmail is string
        && request.resource.data.normalizedPhone is string
        && request.resource.data.notes is string
        && request.resource.data.phone is string
        && validStatus(request.resource.data.status, ['Active', 'Inactive', 'Archived'])
        && request.resource.data.updatedDate is timestamp;
    }

    function validEventLocationDefault() {
      return request.resource.data.keys().hasOnly([
          'address',
          'defaultEventTypes',
          'eventLocationId',
          'isActive',
          'label',
          'sortOrder',
          'updatedDate',
          'value'
        ])
        && request.resource.data.address is string
        && (!('defaultEventTypes' in request.resource.data)
          || request.resource.data.defaultEventTypes is list
            && request.resource.data.defaultEventTypes.hasOnly([
              'Class (Half Day)',
              'Class (Full Day)',
              'Workshop',
              'Retreat',
              'Lecture',
              'Challenges',
              'Other'
            ]))
        && request.resource.data.eventLocationId is string
        && request.resource.data.isActive is bool
        && request.resource.data.label is string
        && request.resource.data.sortOrder is number
        && request.resource.data.updatedDate is timestamp
        && request.resource.data.value is string;
    }

    function validEventTimeDefault() {
      return request.resource.data.keys().hasOnly([
          'endTime',
          'eventTimeId',
          'isActive',
          'label',
          'sortOrder',
          'startTime',
          'updatedDate',
          'value'
        ])
        && request.resource.data.endTime is string
        && request.resource.data.eventTimeId is string
        && request.resource.data.isActive is bool
        && request.resource.data.label is string
        && request.resource.data.sortOrder is number
        && request.resource.data.startTime is string
        && request.resource.data.updatedDate is timestamp
        && request.resource.data.value is string;
    }

    function validCoordinatorAssignment() {
      return request.resource.data.keys().hasOnly([
          'areaLabel',
          'assignedUserEmail',
          'assignedUserId',
          'assignedUserName',
          'assignedUserPhone',
          'contactEmailOverride',
          'contactPhoneOverride',
          'coordinatorAreaId',
          'groupLabel',
          'isActive',
          'sortOrder',
          'updatedDate'
        ])
        && validStatus(request.resource.data.coordinatorAreaId, [
          'programs',
          'workshops',
          'challenges',
          'business-listings',
          'for-sale',
          'membership'
        ])
        && request.resource.data.areaLabel is string
        && request.resource.data.assignedUserEmail is string
        && request.resource.data.assignedUserId is string
        && request.resource.data.assignedUserName is string
        && request.resource.data.assignedUserPhone is string
        && request.resource.data.contactEmailOverride is string
        && request.resource.data.contactPhoneOverride is string
        && request.resource.data.groupLabel is string
        && request.resource.data.isActive is bool
        && request.resource.data.sortOrder is number
        && request.resource.data.updatedDate is timestamp;
    }

    match /events/{eventId} {
      allow read: if resource.data.status == 'Published' || hasPermission('manageEvents');
      allow create, update: if hasPermission('manageEvents') && validEvent();
      allow delete: if hasPermission('manageEvents');
    }

    match /registrations/{registrationId} {
      allow create: if validRegistration();
      allow read: if hasPermission('viewRegistrations') || isOwner(resource.data.userId);
      allow update: if hasPermission('viewRegistrations') && validRegistration()
        || isOwner(resource.data.userId)
          && validRegistration()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
          && request.resource.data.status == 'Cancelled';
      allow delete: if hasPermission('viewRegistrations');
    }

    match /users/{userId} {
      allow read: if isOwner(userId)
        || isSuperUser()
        || isAdmin() && resource.data.role == 'General User';
      allow create: if isSuperUser() && validUser() || validSelfUserCreate(userId) && validUser();
      allow update: if isSuperUser() && validUser()
        || hasPermission('addUsers')
          && resource.data.role == 'General User'
          && validUser()
          && request.resource.data.role == 'General User'
          && hasNoAdminPermissions()
          && (membershipFieldsUnchanged() || membershipStatusEditable())
        || isOwner(userId)
          && validUser()
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.permissions == resource.data.permissions
          && profileTagsUnchanged()
          && membershipFieldsUnchanged();
      allow delete: if isSuperUser();
    }

    match /payments/{paymentId} {
      allow read: if hasPermission('managePayments')
        || hasPermission('viewRegistrations')
        || hasPermission('manageMembershipStatus')
        || signedIn()
          && resource.data.entityType == 'Registration'
          && resource.data.registrationId is string
          && get(/databases/$(database)/documents/registrations/$(resource.data.registrationId)).data.userId == request.auth.uid;
      allow create, update: if (hasPermission('managePayments')
          || hasPermission('viewRegistrations')
          || hasPermission('manageMembershipStatus'))
        && validPayment();
      allow delete: if isSuperUser();
    }

    match /auditLogs/{auditLogId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && validAuditLog();
      allow update, delete: if false;
    }

    match /appSettings/{settingId} {
      allow read: if settingId in ['membership', 'paymentSettings'] || isAdmin();
      allow create, update: if isSuperUser()
        && (
          settingId == 'membership'
            && validMembershipSettings()
          || settingId == 'emailInstructions'
            && validEmailInstructions()
          || settingId == 'paymentSettings'
            && validPaymentSettings()
        );
      allow delete: if isSuperUser();
    }

    match /members/{memberId} {
      allow read: if isSuperUser();
      allow create, update: if isSuperUser() && validMember();
      allow delete: if isSuperUser();
    }

    match /eventLocationDefaults/{eventLocationId} {
      allow read: if isAdmin();
      allow create, update: if isSuperUser() && validEventLocationDefault();
      allow delete: if isSuperUser();
    }

    match /eventTimeDefaults/{eventTimeId} {
      allow read: if isAdmin();
      allow create, update: if isSuperUser() && validEventTimeDefault();
      allow delete: if isSuperUser();
    }

    match /coordinatorAssignments/{coordinatorAreaId} {
      allow read: if isAdmin();
      allow create, update: if isSuperUser()
        && coordinatorAreaId == request.resource.data.coordinatorAreaId
        && validCoordinatorAssignment();
      allow delete: if isSuperUser();
    }
  }
}
