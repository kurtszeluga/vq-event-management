rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function validImageUpload() {
      return request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function validPdfUpload() {
      return request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'application/octet-stream'
        );
    }

    function ownsFolder(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /event-images/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if ownsFolder(userId) && validImageUpload();
      allow delete: if ownsFolder(userId);
    }

    match /event-documents/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if ownsFolder(userId) && validPdfUpload();
      allow delete: if ownsFolder(userId);
    }
  }
}
